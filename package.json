{
  "name": "frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:lowmem": "VITE_ENABLE_DEVTOOLS=0 NODE_OPTIONS=--max-old-space-size=2048 vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "clean:caches": "rm -rf dist node_modules/.vite *.tsbuildinfo",
    "type-check": "npm run i18n:check && vue-tsc --build",
    "chars:fetch-drafts-api": "node scripts/fetch-draft-operator-api.mjs --only-missing",
    "chars:briefs": "node scripts/chars/build-draft-briefs.mjs",
    "chars:audit": "node scripts/chars/audit-character-pipeline.mjs",
    "chars:pipeline": "npm run chars:fetch-drafts-api && npm run chars:briefs && npm run chars:audit",
    "i18n:seed-zh": "TSX_TSCONFIG=tsconfig.app.json tsx -r tsconfig-paths/register scripts/i18n/sync-zh-from-en.ts",
    "i18n:check": "TSX_TSCONFIG=tsconfig.app.json tsx -r tsconfig-paths/register scripts/i18n/check-coverage.ts"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.2.1",
    "vue": "^3.5.29",
    "vue-i18n": "^11.3.2",
    "vue-router": "^4.6.4",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.11.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/tsconfig": "^0.8.1",
    "lightningcss": "^1.32.0",
    "npm-run-all2": "^8.0.4",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.6",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
